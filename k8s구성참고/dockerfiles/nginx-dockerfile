FROM nginx:1.25-alpine

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY backup/dev-web/usr/share/nginx/html.tar /usr/share/nginx/html.tar

RUN apk add --no-cache \
      git \
      curl \
      ca-certificates \
      bash \
      openssh-client \
      unzip

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
