#!/usr/bin/env bash
set -euo pipefail

APP_DIR="{{ java_app_dir }}"
BACKUP_DIR="{{ java_backup_dir | default(java_app_dir ~ '/backup') }}"
JAR_NAME="{{ java_jar_remote_name }}"
TARGET_JAR="${APP_DIR}/${JAR_NAME}"
SERVICE_NAME="{{ java_service_name }}"
SERVICE_USER="{{ service_user }}"

if [[ "${1:-}" == "list" ]]; then
  echo "[INFO] Available backups for ${SERVICE_NAME} in ${BACKUP_DIR}"
  find "${BACKUP_DIR}" -maxdepth 1 -type f -name "${JAR_NAME}.*" | sed 's#^.*/##' | sort -r
  exit 0
fi

REQUESTED_BACKUP="${1:-}"
if [[ -n "${REQUESTED_BACKUP}" && "${REQUESTED_BACKUP}" != "latest" ]]; then
  if [[ -f "${REQUESTED_BACKUP}" ]]; then
    SOURCE_JAR="${REQUESTED_BACKUP}"
  else
    SOURCE_JAR="${BACKUP_DIR}/${REQUESTED_BACKUP}"
  fi
else
  SOURCE_JAR="$(find "${BACKUP_DIR}" -maxdepth 1 -type f -name "${JAR_NAME}.*" | sort -r | head -n 1 || true)"
fi

if [[ -z "${SOURCE_JAR}" || ! -f "${SOURCE_JAR}" ]]; then
  echo "[ERROR] No backup JAR found for ${SERVICE_NAME}."
  echo "[HINT] Run './rollback.sh list' first."
  exit 1
fi

if [[ "$(id -u)" -eq 0 ]]; then
  SUDO=""
else
  SUDO="sudo"
fi

ROLLBACK_MARK="$(date +%Y%m%d%H%M%S)"
if [[ -f "${TARGET_JAR}" ]]; then
  ${SUDO} cp -f "${TARGET_JAR}" "${BACKUP_DIR}/${JAR_NAME}.rollback-before-${ROLLBACK_MARK}"
fi

${SUDO} cp -f "${SOURCE_JAR}" "${TARGET_JAR}"
${SUDO} chown "${SERVICE_USER}:${SERVICE_USER}" "${TARGET_JAR}"
${SUDO} chmod 0644 "${TARGET_JAR}"
${SUDO} systemctl restart "${SERVICE_NAME}"

echo "[OK] Rolled back ${SERVICE_NAME} using $(basename "${SOURCE_JAR}")"
${SUDO} systemctl --no-pager --full status "${SERVICE_NAME}" | sed -n '1,12p'
