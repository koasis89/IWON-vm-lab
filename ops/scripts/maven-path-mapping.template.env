# Maven mode path mapping template for this repository.
# Source build outputs are expected at:
#   release/web/html.zip
#   release/was/app.jar
#   release/app/app.jar
#   release/integration/app.jar
#
# Set these values as pipeline parameters when artifactFeedType=maven.
# These are relative to artifactDownloadDir after DownloadPackage@1.

artifactFeedType=maven
artifactFeedName=ITEYES-Packages
mavenPackageDefinition=com.iteyes:iwon-ops-bundle
mavenPackageVersion=2026.3.29-main
artifactFeedView=release

# Template A: package keeps standard folders under download root.
webHtmlZipRelative=web/html.zip
wasJarRelative=was/app.jar
appJarRelative=app/app.jar
integrationJarRelative=integration/app.jar

# Template B: if maven repo layout nests by group/artifact/version, override like below.
# webHtmlZipRelative=com/iteyes/iwon-ops-bundle/2026.3.29-main/web/html.zip
# wasJarRelative=com/iteyes/iwon-ops-bundle/2026.3.29-main/was/app.jar
# appJarRelative=com/iteyes/iwon-ops-bundle/2026.3.29-main/app/app.jar
# integrationJarRelative=com/iteyes/iwon-ops-bundle/2026.3.29-main/integration/app.jar
