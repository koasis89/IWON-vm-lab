# Centralized OPS defaults for feed-only deployment.
# This file is sourced by pipeline/script automation.

# Feed selection: universal|maven
OPS_DEFAULT_ARTIFACT_FEED_TYPE="universal"

# Feed configuration
OPS_DEFAULT_ARTIFACT_FEED_NAME="ITEYES-Packages"
OPS_DEFAULT_ARTIFACT_FEED_VIEW="release"

# Universal package defaults
OPS_DEFAULT_UNIVERSAL_PACKAGE_NAME="iwon-ops-bundle"
OPS_DEFAULT_UNIVERSAL_PACKAGE_VERSION="2026.3.29-main"

# Maven package defaults
OPS_DEFAULT_MAVEN_PACKAGE_DEFINITION="com.iteyes:iwon-ops-bundle"
OPS_DEFAULT_MAVEN_PACKAGE_VERSION="2026.3.29-main"

# Download/output defaults
OPS_DEFAULT_ARTIFACT_DOWNLOAD_DIR="downloaded-artifacts"

# Optional explicit relative paths (if empty, pipeline auto-detects by pattern)
OPS_DEFAULT_WEB_HTML_ZIP_RELATIVE=""
OPS_DEFAULT_WAS_JAR_RELATIVE=""
OPS_DEFAULT_APP_JAR_RELATIVE=""
OPS_DEFAULT_INTEGRATION_JAR_RELATIVE=""

# Auto-detection defaults when explicit relative path is empty
OPS_DEFAULT_WEB_COMPONENT_DIR="web"
OPS_DEFAULT_WAS_COMPONENT_DIR="was"
OPS_DEFAULT_APP_COMPONENT_DIR="app"
OPS_DEFAULT_INTEGRATION_COMPONENT_DIR="integration"

OPS_DEFAULT_WEB_FILE_PATTERN="*.zip"
OPS_DEFAULT_WAS_FILE_PATTERN="*.jar"
OPS_DEFAULT_APP_FILE_PATTERN="*.jar"
OPS_DEFAULT_INTEGRATION_FILE_PATTERN="*.jar"
